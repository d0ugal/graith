{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:best-practices'],
  automerge: true,
  packageRules: [
    { matchManagers: ['gomod'], enabled: true },
    { matchManagers: ['gomod'], postUpdateOptions: ['gomodTidy'] },
    { matchManagers: ['gomod'], commitMessagePrefix: 'fix:', commitMessageAction: 'update' },
    {
      // config:best-practices enables docker:pinDigests, but the golangci-lint
      // image tag lives in a Makefile variable (GOLANGCI_LINT_VERSION := vX.Y.Z)
      // and is referenced as golangci/golangci-lint:$(GOLANGCI_LINT_VERSION) in
      // several commands. A digest can't be written into that variable
      // reference — the custom regex manager only captures the version — so the
      // pin-dependencies branch errors with "update failure". Track this image
      // by version only. See dependency dashboard #90.
      matchDepNames: ['golangci/golangci-lint'],
      matchDatasources: ['docker'],
      pinDigests: false,
    },
    {
      // gvisor.dev/gvisor is a transitive dependency of tailscale.com, which
      // pins the exact revision it needs. gvisor's repo is Bazel-structured, so
      // arbitrary upstream commits don't compile with `go build` (e.g. a stray
      // `package bridge` test file in pkg/tcpip/stack). Let the pin track
      // tailscale rather than the latest digest. See closed PR #875.
      matchPackageNames: ['gvisor.dev/gvisor'],
      enabled: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: ['/Makefile/'],
      matchStrings: ['GOLANGCI_LINT_VERSION := (?<currentValue>v[\\d\\.]+)'],
      depNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
    },
    {
      // Keep the nono version CI tests against on the latest release. The
      // sandbox workflow verifies the download by build-provenance attestation
      // (version-independent), so only this version string needs bumping.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/sandbox\\.yml$/'],
      matchStrings: ['NONO_VERSION:\\s*"(?<currentValue>[\\d.]+)"'],
      depNameTemplate: 'nolabs-ai/nono',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      // Keep actionlint on the latest release. The workflow-lint workflow
      // verifies the download by build-provenance attestation
      // (version-independent), so only this version string needs bumping.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/workflow-lint\\.yml$/'],
      matchStrings: ['ACTIONLINT_VERSION:\\s*(?<currentValue>[\\d.]+)'],
      depNameTemplate: 'rhysd/actionlint',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      // Keep zizmor on the latest release. Same provenance-verified,
      // version-independent install as actionlint/nono — only the version
      // string bumps; the attestation check needs no per-version update.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/workflow-lint\\.yml$/'],
      matchStrings: ['ZIZMOR_VERSION:\\s*(?<currentValue>[\\d.]+)'],
      depNameTemplate: 'zizmorcore/zizmor',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
  ],
}
