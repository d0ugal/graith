{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:best-practices'],
  automerge: true,
  packageRules: [
    { matchManagers: ['gomod'], enabled: true },
    { matchManagers: ['gomod'], postUpdateOptions: ['gomodTidy'] },
    { matchManagers: ['gomod'], commitMessagePrefix: 'fix:', commitMessageAction: 'update' },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: ['/Makefile/'],
      matchStrings: ['GOLANGCI_LINT_VERSION := (?<currentValue>v[\\d\\.]+)'],
      depNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
    },
    {
      // Keep the nono version CI tests against on the latest release. The
      // sandbox workflow verifies the download by build-provenance attestation
      // (version-independent), so only this version string needs bumping.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/sandbox\\.yml$/'],
      matchStrings: ['NONO_VERSION:\\s*"(?<currentValue>[\\d.]+)"'],
      depNameTemplate: 'nolabs-ai/nono',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
  ],
}
