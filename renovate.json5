{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:best-practices'],
  automerge: true,
  packageRules: [
    { matchManagers: ['gomod'], enabled: true },
    { matchManagers: ['gomod'], postUpdateOptions: ['gomodTidy'] },
    { matchManagers: ['gomod'], commitMessagePrefix: 'fix:', commitMessageAction: 'update' },
    {
      // go-libghostty is only safe to update through the native lock manager
      // below. A gomod-only branch would omit the matching Ghostty archive,
      // headers, checksums, licenses, SPDX inventory, and native validation.
      matchManagers: ['gomod'],
      matchPackageNames: ['go.mitchellh.com/libghostty'],
      enabled: false,
      automerge: false,
    },
    {
      matchDepTypes: ['libghostty-native'],
      groupName: 'libghostty native dependency unit',
      groupSlug: 'libghostty-native',
      automerge: false,
      rangeStrategy: 'replace',
      commitMessagePrefix: 'fix:',
      commitMessageAction: 'update',
      commitMessageTopic: 'native libghostty dependency unit',
      prBodyNotes: [
        'This group is an exact native dependency unit and must never be automerged.',
        'The generation task rotates go.mod/go.sum, Ghostty and wrapper revisions, the Apple artifact, Zig/transitive source and license hashes, committed headers, SPDX, and notices. A red generation check means the selected releases are not present in the selected Ghostty commit or the reviewed Apple artifact has not been published yet.',
        'If license or embedded-notice hashes changed, inspect the exact evidence and run scripts/libghostty-native.sh accept-license-reviews before regenerating. Run every required libghostty native check before merge. See the contributing guide for commit-pinned and vendored discovery rules.',
      ],
    },
    {
      // The wrapper's CMakeLists.txt is the compatibility authority for the
      // normal unit update. Newer Ghostty/transitive releases stay visible on
      // the dependency dashboard, but require explicit approval before they
      // can propose a graph that differs from the wrapper-tested closure.
      matchDepTypes: ['libghostty-native'],
      matchDepNames: ['Ghostty', 'Zig', 'uucode', 'Highway', 'simdutf'],
      dependencyDashboardApproval: true,
    },
    {
      // config:best-practices enables docker:pinDigests, but the golangci-lint
      // image tag lives in a Makefile variable (GOLANGCI_LINT_VERSION := vX.Y.Z)
      // and is referenced as golangci/golangci-lint:$(GOLANGCI_LINT_VERSION) in
      // several commands. A digest can't be written into that variable
      // reference — the custom regex manager only captures the version — so the
      // pin-dependencies branch errors with "update failure". Track this image
      // by version only. See dependency dashboard #90.
      matchDepNames: ['golangci/golangci-lint'],
      matchDatasources: ['docker'],
      pinDigests: false,
    },
    {
      // gvisor.dev/gvisor is a transitive dependency of tailscale.com, which
      // pins the exact revision it needs. gvisor's repo is Bazel-structured, so
      // arbitrary upstream commits don't compile with `go build` (e.g. a stray
      // `package bridge` test file in pkg/tcpip/stack). Let the pin track
      // tailscale rather than the latest digest. See closed PR #875.
      matchPackageNames: ['gvisor.dev/gvisor'],
      enabled: false,
    },
    {
      // These modules are transitive dependencies whose versions are pinned by
      // their parents — go-proxyproto, rtnetlink and wireguard-go by
      // tailscale.com, and libc by modernc.org/sqlite. graith does not import
      // any of them directly (`go mod why` traces every one through
      // tailscale.com or modernc.org/sqlite). Bumping them independently
      // overrides the exact version the parent was tested against, and the only
      // updates on offer are breaking majors/digests that risk breaking the
      // parent's own compilation: go-proxyproto v0.15 changes the PROXY-protocol
      // spec (2.3→3.4), rtnetlink v2 changes the LinkDriver API, and libc v2 is
      // a new module path. Let these pins track the parent instead, mirroring
      // the gvisor.dev/gvisor rule above. See closed PRs #960 (go-proxyproto),
      // #932 (rtnetlink), #659 (libc) and dependency dashboard #90.
      matchPackageNames: [
        'github.com/pires/go-proxyproto',
        'github.com/jsimonetti/rtnetlink',
        'github.com/tailscale/wireguard-go',
        'modernc.org/libc',
      ],
      enabled: false,
    },
  ],
  customManagers: [
    {
      // Commit-only repositories follow the selected branch digest. The update
      // command resolves go-libghostty's digest to its Go pseudo-version.
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"goLibghostty":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"renovateRef":\\s*"(?<currentValue>[^"]+)",\\s*"commit":\\s*"(?<currentDigest>[0-9a-f]{40})"',
      ],
      datasourceTemplate: 'git-refs',
      depNameTemplate: 'go-libghostty',
      depTypeTemplate: 'libghostty-native',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"ghostty":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"renovateRef":\\s*"(?<currentValue>[^"]+)",\\s*"commit":\\s*"(?<currentDigest>[0-9a-f]{40})"',
      ],
      datasourceTemplate: 'git-refs',
      depNameTemplate: 'Ghostty',
      depTypeTemplate: 'libghostty-native',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"zig":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"version":\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-tags',
      depNameTemplate: 'Zig',
      depTypeTemplate: 'libghostty-native',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"uucode":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"version":\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-tags',
      depNameTemplate: 'uucode',
      depTypeTemplate: 'libghostty-native',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"highway":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"version":\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-tags',
      depNameTemplate: 'Highway',
      depTypeTemplate: 'libghostty-native',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"simdutf":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"version":\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-tags',
      depNameTemplate: 'simdutf',
      depTypeTemplate: 'libghostty-native',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/^libghostty-native\\.lock\\.json$/'],
      matchStrings: [
        '"spdxTools":\\s*\\{\\s*"repository":\\s*"(?<packageName>[^"]+)",\\s*"version":\\s*"(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-releases',
      depNameTemplate: 'SPDX tools-java',
      depTypeTemplate: 'libghostty-native',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: ['/Makefile/'],
      matchStrings: ['GOLANGCI_LINT_VERSION := (?<currentValue>v[\\d\\.]+)'],
      depNameTemplate: 'golangci/golangci-lint',
      datasourceTemplate: 'docker',
      versioningTemplate: 'semver',
    },
    {
      // Keep the nono version CI tests against on the latest release. The
      // sandbox workflow verifies the download by build-provenance attestation
      // (version-independent), so only this version string needs bumping.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/sandbox\\.yml$/'],
      matchStrings: ['NONO_VERSION:\\s*"(?<currentValue>[\\d.]+)"'],
      depNameTemplate: 'nolabs-ai/nono',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      // Keep actionlint on the latest release. The workflow-lint workflow
      // verifies the download by build-provenance attestation
      // (version-independent), so only this version string needs bumping.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/workflow-lint\\.yml$/'],
      matchStrings: ['ACTIONLINT_VERSION:\\s*(?<currentValue>[\\d.]+)'],
      depNameTemplate: 'rhysd/actionlint',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
    {
      // Keep zizmor on the latest release. Same provenance-verified,
      // version-independent install as actionlint/nono — only the version
      // string bumps; the attestation check needs no per-version update.
      customType: 'regex',
      managerFilePatterns: ['/^\\.github/workflows/workflow-lint\\.yml$/'],
      matchStrings: ['ZIZMOR_VERSION:\\s*(?<currentValue>[\\d.]+)'],
      depNameTemplate: 'zizmorcore/zizmor',
      datasourceTemplate: 'github-releases',
      extractVersionTemplate: '^v(?<version>.+)$',
      versioningTemplate: 'semver',
    },
  ],
}
